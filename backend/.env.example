# ══════════════════════════════════════════════
# Warif Backend — Environment Template
# Copy this file to .env and fill in real values
# ══════════════════════════════════════════════

# ── Database ───────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=warif
DB_USER=warif_user
DB_PASSWORD=changeme

# ── JWT ────────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── Tuya IoT ───────────────────────────────────
TUYA_ACCESS_ID=your-tuya-access-id
TUYA_ACCESS_SECRET=your-tuya-access-secret
TUYA_API_ENDPOINT=https://openapi.tuyaeu.com
TUYA_POLL_INTERVAL=30

# ── Chatbot / RAG ──────────────────────────────
GROQ_API_KEY=your-groq-api-key
CHROMA_DB_PATH=./src/chatbot/chroma_db_warif_arabic
CHROMA_COLLECTION=warif_arabic
GROQ_MODEL=llama-3.1-8b-instant

# ── Notifications ──────────────────────────────
SLACK_WEBHOOK_URL=

# ── App ────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
