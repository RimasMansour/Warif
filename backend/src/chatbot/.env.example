# .env.example for chatbot
# Copy this to .env and fill in your actual values
# Never commit .env to git

# Required: Groq API key (get from https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Optional: Chroma DB configuration
CHROMA_DB_PATH=./src/chatbot/chroma_db
CHROMA_COLLECTION=warif_knowledge

# Embedding model
EMBEDDING_MODEL=paraphrase-multilingual-mpnet-base-v2

# Groq model options (free tier):
# - llama-3.1-8b-instant   (fastest, good Arabic)
# - llama-3.3-70b-versatile (slower, better quality)
# - gemma2-9b-it (Google model, multilingual)
GROQ_MODEL=llama-3.1-8b-instant
