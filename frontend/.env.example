# Warif Frontend Environment Configuration
# Copy this file to .env and update values for your environment

# Backend API base URL (must include protocol and port, no trailing slash)
VITE_API_URL=http://localhost:8000

# Optional: Set to true to enable debug logging in the browser console
VITE_DEBUG=false

# Optional: Request timeout in milliseconds (default: 30000)
VITE_REQUEST_TIMEOUT=30000

# Optional: Automatic retry attempts for failed API requests (default: 3)
VITE_API_RETRY_ATTEMPTS=3

# Optional: Delay between retries in milliseconds (default: 1000)
VITE_API_RETRY_DELAY=1000

# Optional: Sensors data refresh interval in milliseconds (default: 10000)
VITE_SENSORS_INTERVAL=10000

# Optional: Recommendations refresh interval in milliseconds (default: 10000)
VITE_RECOMMENDATIONS_INTERVAL=10000

# Optional: Alerts refresh interval in milliseconds (default: 10000)
VITE_ALERTS_INTERVAL=10000
